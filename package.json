{
  "name": "async-framework-demo",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Async framework demo with cacheable server resources, generated component output, streaming, and MiniWeb-backed static routes.",
  "scripts": {
    "start": "node server.mjs",
    "prepare:static": "node scripts/copy-miniweb-assets.mjs",
    "start:static": "npm run prepare:static && node scripts/static-server.mjs",
    "build:pages": "node scripts/build-pages.mjs",
    "generate": "node generate.mjs",
    "check": "find . -type f \\( -name '*.js' -o -name '*.mjs' \\) -not -path './.git/*' -not -path './node_modules/*' -not -path './dist-pages/*' -not -path './sw-demo/assets/miniweb/*' -print0 | xargs -0 -n 1 node --check",
    "smoke": "node scripts/smoke.mjs",
    "smoke:sw": "npm run prepare:static && node scripts/sw-smoke.mjs"
  },
  "license": "MIT",
  "dependencies": {
    "@async/miniweb": "0.1.0"
  }
}
